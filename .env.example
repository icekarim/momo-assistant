# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id

# Google Auth (user OAuth for Gmail, Calendar, and Tasks)
# Local bootstrap writes token.json.
# Cloud Run seeds Firestore google_auth/token from that file.
# GOOGLE_TOKEN_JSON is only a seed / break-glass fallback, Firestore is the durable source of truth.
# Keep the OAuth consent screen out of External or Testing for production, because refresh tokens can expire after 7 days there.
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json
# Public Cloud Run base URL used for self-serve reauth links
MOMO_SERVICE_URL=https://your-cloud-run-url
# Cloud Run seed / break-glass fallback for Google OAuth token JSON
GOOGLE_TOKEN_JSON=

# Google Chat space ID (you'll get this when the bot is first added)
# Format: spaces/XXXXXXXXX
CHAT_SPACE_ID=

# Proactive email alerts
EMAIL_ALERTS_ENABLED=true
EMAIL_ALERT_GMAIL_QUERY=is:unread in:inbox newer_than:2d
EMAIL_ALERTS_MAX_PER_RUN=5
IMPORTANT_EMAIL_KEYWORDS=urgent,asap,important,action required,deadline,escalation,blocker
CLIENT_EMAIL_KEYWORDS=client,customer
# Optional comma-separated list, e.g. acme.com,clientco.io
CLIENT_DOMAINS=

# Granola meeting notes (via MCP)
# Run `python granola_auth_setup.py` once — token is saved to
# granola_token.json (local) and Firestore (Cloud Run).
# Auto-refreshes everywhere, no manual token management needed.
GRANOLA_ENABLED=true
GRANOLA_MCP_URL=https://mcp.granola.ai/mcp
MEETING_DEBRIEF_LOOKBACK_MINUTES=15

# Jira tickets (via REST API)
# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_ENABLED=false
JIRA_SITE_URL=yoursite.atlassian.net
JIRA_USER_EMAIL=you@company.com
JIRA_API_TOKEN=
# Optional: customize the JQL filter for which tickets to surface
# Default fetches tickets where you are assignee, reporter, or watcher
# JIRA_JQL_FILTER=(assignee = currentUser() OR reporter = currentUser() OR watcher = currentUser()) AND statusCategory != Done ORDER BY updated DESC
